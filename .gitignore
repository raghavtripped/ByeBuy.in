# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# Ignore top-level .env files (like .env.local)
.env*
# Specifically ignore .env files within any Supabase function directory
# This is crucial for keeping SERVICE_ROLE_KEY etc out of Git
.supabase/functions/*/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase specific ignores
# Ignore sensitive linking file if generated by older CLI versions
.supabase/project_id_file
# Ignore local development database files (if using local db)
# .supabase/db/generated_schema.sql # Usually good to track schema
# .supabase/db/init.sql # Usually good to track init script
# Add other specific .supabase files/dirs to ignore if needed,
# but generally KEEP config.toml and the migrations directory tracked.